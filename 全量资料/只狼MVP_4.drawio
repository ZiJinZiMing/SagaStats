        <mxCell id="dstLN57wYbqUIXLDyb3q-523" parent="dstLN57wYbqUIXLDyb3q-521" style="rounded=0;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;" value="&lt;span style=&quot;font-size: 12px;&quot;&gt;毒槽满&lt;/span&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;判定：Meter_Poison为满&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;毒累积值计算：GEModifier动态公式：&lt;/span&gt;&lt;span style=&quot;text-align: center;&quot;&gt;poizonAttackPower&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;text-align: center;&quot;&gt;/ (&lt;/span&gt;&lt;span style=&quot;text-align: center; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;resist_poison / 100&lt;/span&gt;&lt;span style=&quot;text-align: center; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;角色允许有中毒反应时毒槽满会播放中毒反应动画，且中毒过程中不会再有&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;毒&lt;/span&gt;&lt;span style=&quot;font-size: 12px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;累积&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 12px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;NPC：&lt;/span&gt;&lt;span style=&quot;font-size: 12px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Hurt/Guard/&lt;/span&gt;&lt;span style=&quot;font-size: 12px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;JustGuard 全积累毒&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 12px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;主角：Hurt/Guard都会积累毒，&lt;/span&gt;&lt;span style=&quot;font-size: 12px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;JustGuard不会积累&lt;/span&gt;&lt;/div&gt;&lt;div&gt;毒的&quot;先占&quot;机制：最终毒槽满的中毒效果由第一次中毒类型决定&lt;span style=&quot;font-size: 12px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 12px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="99.25" width="465" x="15" y="70.75" as="geometry" />
        </mxCell>
